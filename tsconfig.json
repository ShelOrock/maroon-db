{
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  },
  "compilerOptions": {
    "outDir": "dist",
    "rootDirs": [ "./database", "./test" ],
    "sourceMap": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "target": "esnext",
    "allowJs": true,
    "allowSyntheticDefaultImports": true
  }
}